{
  "expo": {
    "name": "PlotTime",
    "slug": "serietime",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "serietime",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/branding/icon-universal-ios-1024.png",
    "splash": {
      "image": "./assets/branding/icon-universal-ios-1024.png",
      "backgroundColor": "#0B075A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plottime.app",
      "usesAppleSignIn": true,
      "icon": "./assets/branding/icon-universal-ios-1024.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.plottime.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/android-adaptive-foreground-1024.png",
        "backgroundColor": "#0B075A",
        "monochromeImage": "./assets/branding/android-monochrome-1024.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/branding/pwa-icon-192.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "PlotTime accède à vos photos pour choisir votre photo de profil et votre bannière."
        }
      ]
    ],
    "extra": {
      "serverUrl": "https://serietime.studio-vives.fr",
      "router": {
        "asyncRoutes": {
          "web": true
        }
      },
      "eas": {
        "projectId": "bc87e346-1117-4da1-975d-c5c2c97fdf61"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
